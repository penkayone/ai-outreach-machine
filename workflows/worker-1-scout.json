    {
      "parameters": {
        "jsCode": "// Парсим текстовый ответ от Overpass.\n// Если ответ — валидный JSON с elements — успех.\n// Если текст ошибки или битый JSON — провал, передаём дальше на fallback.\n\nconst resp = $input.first().json;\nconst text = resp.data || '';\n\nif (!text || typeof text !== 'string') {\n  return [{ json: { ok: false, error: 'Empty or non-string response', endpoint_tried: 'overpass-api.de' } }];\n}\n\ntry {\n  const parsed = JSON.parse(text);\n  if (parsed && Array.isArray(parsed.elements)) {\n    return [{\n      json: {\n        ok: true,\n        elements: parsed.elements,\n        elements_count: parsed.elements.length,\n        endpoint_used: 'overpass-api.de'\n      }\n    }];\n  }\n  return [{ json: { ok: false, error: 'JSON parsed but no elements array', endpoint_tried: 'overpass-api.de' } }];\n} catch (e) {\n  return [{\n    json: {\n      ok: false,\n      error: 'JSON parse failed: ' + String(e.message).substring(0, 100),\n      raw_preview: text.substring(0, 300),\n      endpoint_tried: 'overpass-api.de'\n    }\n  }];\n}"
      },
