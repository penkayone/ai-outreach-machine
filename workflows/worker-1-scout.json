    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst elements = response.elements || [];\nconst ctx = $('Merge Context').first().json;\nconst today = new Date().toISOString().split('T')[0];\n\nconst existing = new Set(ctx.existing_websites || []);\n\nconst normalizeWebsite = (url) => {\n  if (!url) return '';\n  let u = String(url).trim().toLowerCase();\n  if (!u.startsWith('http://') && !u.startsWith('https://')) {\n    u = 'https://' + u;\n  }\n  u = u.replace(/\\/$/, '');\n  return u;\n};\n\nconst newLeads = [];\nconst seen = new Set();\nlet skippedExisting = 0;\nlet skippedNoWebsite = 0;\nlet skippedNoName = 0;\nlet skippedDupInBatch = 0;\n\nfor (const el of elements) {\n  const tags = el.tags || {};\n  const name = tags.name || tags['name:en'] || '';\n  if (!name) { skippedNoName++; continue; }\n\n  const website = normalizeWebsite(\n    tags.website ||\n    tags['contact:website'] ||\n    tags.url ||\n    ''\n  );\n\n  if (!website) { skippedNoWebsite++; continue; }\n  if (existing.has(website)) { skippedExisting++; continue; }\n  if (seen.has(website)) { skippedDupInBatch++; continue; }\n  seen.add(website);\n\n  const email = tags.email || tags['contact:email'] || '';\n  const city = tags['addr:city'] || tags['addr:town'] || tags['addr:village'] || '';\n\n  newLeads.push({\n    json: {\n      company_name: name.trim().substring(0, 200),\n      website: website,\n      email: email,\n      city: city,\n      country: ctx.country_name,\n      language: '',\n      source: 'openstreetmap',\n      source_url: `https://www.openstreetmap.org/${el.type}/${el.id}`,\n      date_added: today,\n      score: '',\n      pain: '',\n      size: '',\n      status: 'scraped',\n      notes: ''\n    }\n  });\n}\n\nconsole.log(`[Scout v4.8] Country: ${ctx.country_iso} | Endpoint: ${response.endpoint_used} | OSM total: ${elements.length} | Existing in Leads: ${ctx.existing_count} | New: ${newLeads.length} | Skipped existing: ${skippedExisting} | Skipped no website: ${skippedNoWebsite}`);\n\nreturn newLeads;"
      },
