      "parameters": {
        "jsCode": "const country = $('Pick Country').first().json;\nconst existingItems = $('Read Existing Leads').all();\n\nconst existingWebsites = [];\nfor (const item of existingItems) {\n  const w = item.json && item.json.website;\n  if (w) existingWebsites.push(String(w).trim().toLowerCase());\n}\n\nreturn [{\n  json: {\n    current_page: country.current_page,\n    country_iso: country.country_iso,\n    country_name: country.country_name,\n    overpass_query: country.overpass_query,\n    existing_websites: existingWebsites,\n    existing_count: existingWebsites.length\n  }\n}];"
