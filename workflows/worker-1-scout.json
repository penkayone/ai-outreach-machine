      "parameters": {
        "jsCode": "const countries = [\n  { iso: 'NL', name: 'Netherlands' },\n  { iso: 'PL', name: 'Poland' },\n  { iso: 'CZ', name: 'Czech Republic' }\n];\n\nconst page = parseInt($input.first().json.value) || 1;\nconst idx = (page - 1) % countries.length;\nconst target = countries[idx];\n\nconst query = `[out:json][timeout:90];\narea[\"ISO3166-1\"=\"${target.iso}\"][\"admin_level\"=\"2\"]->.country;\n(\n  node[\"office\"=\"estate_agent\"](area.country);\n  way[\"office\"=\"estate_agent\"](area.country);\n);\nout center tags;`;\n\nreturn [{\n  json: {\n    current_page: page,\n    country_iso: target.iso,\n    country_name: target.name,\n    overpass_query: query\n  }\n}];"
      },
