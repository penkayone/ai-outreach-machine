      "id": "9f1516d2-cddd-4a32-95d0-bf422458949b",
      "name": "Get Draft Ready Emails",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.4,
      "position": [
        -880,
        112
      ],
      "executeOnce": true,
      "credentials": {
        "googleApi": {
          "id": "YOUR_GOOGLE_SHEETS_CRED_ID",
          "name": "Google Sheets account 3"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Берём одно первое письмо из очереди (FIFO — первое по дате генерации).\n// Rate limit: 1 письмо за запуск workflow (запуски каждые 10 минут = 6/час).\n\nconst all = $input.all();\n\nif (all.length === 0) {\n  console.log(`[Sender v1.0] No draft_ready emails in queue.`);\n  return [];\n}\n\nconsole.log(`[Sender v1.0] Queue size: ${all.length}. Taking first email.`);\n\nreturn [all[0]];"
      },
      "id": "65a7a4a4-d98e-4292-a9aa-39882e6003c3",
      "name": "Take First Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -656,
        112
      ]
    },
    {
      "parameters": {
        "jsCode": "// Собираем итоговое письмо:\n// 1. Случайно выбираем subject_a или subject_b (A/B 50/50)\n// 2. Формируем HTML body с preheader в скрытом span\n// 3. Подготавливаем данные для отправки через SMTP\n\nconst outreach = $json;\n\n// --- A/B выбор subject ---\nconst useA = Math.random() < 0.5;\nconst chosenSubject = useA ? (outreach.subject_a || '') : (outreach.subject_b || outreach.subject_a || '');\nconst subjectVariant = useA ? 'A' : 'B';\n\nif (!chosenSubject || !outreach.body) {\n  throw new Error(`Missing subject or body for ${outreach.email}. subject_a=${outreach.subject_a}, subject_b=${outreach.subject_b}, body_len=${(outreach.body || '').length}`);\n}\n\nif (!outreach.email || !outreach.email.includes('@')) {\n  throw new Error(`Invalid email: ${outreach.email}`);\n}\n\n// --- HTML body ---\n// Конвертируем переносы строк в <br>, preheader в скрытом span в начале\nconst preheader = (outreach.preheader || '').substring(0, 100);\nconst bodyHtml = outreach.body\n  .replace(/&/g, '&amp;')\n  .replace(/</g, '&lt;')\n  .replace(/>/g, '&gt;')\n  .replace(/\\n/g, '<br>\\n');\n\nconst html = `<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n</head>\n<body style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif; font-size: 14px; color: #333; line-height: 1.5;\">\n<span style=\"display:none !important; visibility:hidden; opacity:0; color:transparent; height:0; width:0; overflow:hidden;\">${preheader}</span>\n<div>\n${bodyHtml}\n</div>\n</body>\n</html>`;\n\n// Plain text версия (для клиентов без HTML)\nconst textVersion = outreach.body;\n\nreturn [{\n  json: {\n    _to_email: outreach.email,\n    _to_name: outreach.company_name || '',\n    _subject: chosenSubject,\n    _html: html,\n    _text: textVersion,\n    _subject_variant: subjectVariant,\n    _website: outreach.website,\n    _company_name: outreach.company_name,\n    _language: outreach.language,\n    _original_body: outreach.body\n  }\n}];"
      },
