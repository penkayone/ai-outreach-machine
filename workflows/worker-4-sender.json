    {
      "parameters": {
        "jsCode": "// Проверяем рабочие часы (10:00-19:00 по CET, пн-пт).\n// Если сейчас не рабочее время — возвращаем пустой массив, workflow остановится.\n\nconst now = new Date();\n// Переводим в CET (UTC+1 зимой, UTC+2 летом — используем UTC+2 как приближение)\nconst cetHour = (now.getUTCHours() + 2) % 24;\nconst dayOfWeek = now.getUTCDay(); // 0=вс, 1-5=пн-пт, 6=сб\n\nconst isWeekday = dayOfWeek >= 1 && dayOfWeek <= 5;\nconst isBusinessHour = cetHour >= 10 && cetHour < 19;\n\nconsole.log(`[Sender v1.0] Time check: CET hour=${cetHour}, day=${dayOfWeek}, weekday=${isWeekday}, businessHour=${isBusinessHour}`);\n\nif (!isWeekday || !isBusinessHour) {\n  console.log(`[Sender v1.0] Outside business hours — skipping this run.`);\n  return [];\n}\n\n// Рабочее время — продолжаем\nreturn [{ json: { proceed: true, cet_hour: cetHour, day: dayOfWeek } }];"
      },
      "id": "b2f9202c-aae5-4984-aa3a-5a51c7744434",
      "name": "Check Business Hours",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1104,
        112
      ]
    },
    {
      "parameters": {
