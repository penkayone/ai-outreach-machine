        "jsCode": "// Обработка ошибки отправки SMTP.\n// Письмо не ушло — помечаем статус send_failed и записываем причину.\n\nconst emailData = $('Build Email Content').item.json;\nconst errorMsg = $json.error?.message || $json.message || JSON.stringify($json).substring(0, 200);\n\nconsole.error(`[Sender v1.0] SMTP send failed for ${emailData._to_email}: ${errorMsg}`);\n\nreturn [{\n  json: {\n    _website: emailData._website,\n    _error: 'send_failed: ' + errorMsg.substring(0, 300)\n  }\n}];"
